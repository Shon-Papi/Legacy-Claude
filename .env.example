# Anthropic API Key (required for AI agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Symbols to watch (comma-separated)
WATCH_SYMBOLS=AAPL,TSLA,NVDA,SPY,QQQ

# Trading mode: paper or live
TRADING_MODE=paper

# Confluence threshold: minimum agents that must agree (1-5)
CONFLUENCE_THRESHOLD=3

# Scan interval in seconds
SCAN_INTERVAL=300

# Email notifications (optional)
NOTIFY_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# News / Event Guard settings
EVENT_GUARD_INTERVAL=60      # seconds between guard checks
NEWS_BIAS_INTERVAL=30        # minutes between full bias refreshes
BIAS_FILTER_THRESHOLD=0.65   # confidence above which bias filters signals

# Alpaca API (optional, for live trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

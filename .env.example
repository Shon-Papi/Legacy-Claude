# =============================================================
# Multi-Agent Trading Bot — environment configuration template
# Copy this file to .env and fill in your values.
# =============================================================

# ── Anthropic (required) ──────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Symbols to watch ─────────────────────────────────────────
WATCH_SYMBOLS=AAPL,TSLA,NVDA,SPY,QQQ

# ── Trading mode: paper | live ────────────────────────────────
TRADING_MODE=paper

# ── Signal confluence ─────────────────────────────────────────
# Minimum number of agents (out of 5) that must agree before a trade fires
CONFLUENCE_THRESHOLD=3

# ── Scan timing ───────────────────────────────────────────────
SCAN_INTERVAL=300           # seconds between full symbol scans
EVENT_GUARD_INTERVAL=60     # seconds between event-guard checks between scans
NEWS_BIAS_INTERVAL=30       # minutes between full news-bias refreshes

# ── Bias filter ───────────────────────────────────────────────
# Suppress signals that oppose a bias above this confidence level (0–1)
BIAS_FILTER_THRESHOLD=0.65

# ── Market-hours gate ─────────────────────────────────────────
# Set to false to allow scanning outside NYSE/NASDAQ regular hours
ONLY_TRADE_MARKET_HOURS=true

# ── Risk management ───────────────────────────────────────────
# Stop trading for the day once realized P&L falls below X% of starting capital
MAX_DAILY_LOSS_PCT=0.02       # 2%
# Stop trading if the portfolio drawdown from its peak exceeds X%
MAX_DRAWDOWN_PCT=0.05         # 5%
# Maximum number of trades executed per calendar day
DAILY_TRADE_LIMIT=10

# ── Alpaca (required for TRADING_MODE=live) ───────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper endpoint (default). Switch to https://api.alpaca.markets for live funds.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Email notifications (optional) ───────────────────────────
NOTIFY_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password    # Use a Gmail App Password, not your account password

# ── Journal ───────────────────────────────────────────────────
# Path for the JSONL trade journal (default: trades_journal.jsonl in cwd)
# JOURNAL_FILE=trades_journal.jsonl
